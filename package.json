{
  "name": "story-fab",
  "productName": "StoryFab",
  "private": true,
  "version": "2.0.0",
  "description": "开源自研AI视频创作工具 · 智能拆条+解说生成+配音合成 · 9:16/1:1/16:9多格式导出 · 本地Whisper字幕 · Rust渲染管线 · 无需上传",
  "author": "Agions <agions@qq.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:budget": "node scripts/check-bundle-budget.mjs",
    "build:ci": "npm run build && npm run build:budget",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "tauri": "tauri",
    "tauri:build:dmg": "bash scripts/build-dmg.sh",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings 200",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,less}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,less}\"",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:run": "npx vitest run",
    "docs:build": "npx vitepress build docs",
    "docs:preview": "npx vitepress preview docs",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.8",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.4.2",
    "antd": "^5.29.3",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vuepress/theme-default": "^1.9.10",
    "autoprefixer": "^10.5.0",
    "babel-plugin-import": "^1.13.8",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "docsify-cli": "^4.4.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "jsdom": "^26.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "less": "^4.2.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "terser": "^5.46.0",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.1",
    "typescript": "^5.7.3",
    "vite": "^6.2.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  }
}
